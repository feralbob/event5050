<div class="min-h-screen flex items-center justify-center bg-base-200">
  <div class="card w-full max-w-md bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title text-2xl font-bold text-center mb-6">Sign In</h2>
      
      <div id="sign-in-form">
        <%= form_with(scope: :session, url: customers_session_path, 
                      local: false, data: { controller: "webauthn-login" }) do |form| %>
          <div class="form-control mb-6">
            <%= form.label :email, class: "label" %>
            <%= form.email_field :email, 
                class: "input input-bordered w-full", 
                placeholder: "john@example.com",
                required: true,
                data: { webauthn_login_target: "email" } %>
          </div>

          <div class="form-control">
            <%= form.submit "Continue", 
                class: "btn btn-primary w-full",
                data: { webauthn_login_target: "submit" } %>
          </div>
        <% end %>
      </div>

      <div id="webauthn-prompt" class="hidden" data-webauthn-login-target="prompt">
        <div class="text-center">
          <div class="loading loading-spinner loading-lg text-primary mb-4"></div>
          <p class="text-lg font-semibold mb-2">Authenticating...</p>
          <p class="text-base-content/70">Please use your security key or biometric authentication.</p>
        </div>
      </div>

      <div id="error-message" class="hidden alert alert-error mt-4" data-webauthn-login-target="error">
        <span data-webauthn-login-target="errorText"></span>
      </div>

      <div class="divider">OR</div>

      <div class="text-center space-y-2">
        <p class="text-sm">
          Don't have an account?
          <%= link_to "Create account", new_customers_registration_path, class: "link link-primary" %>
        </p>
        <p class="text-sm">
          <%= link_to "Resend confirmation email", new_customers_confirmation_path, class: "link link-secondary" %>
        </p>
      </div>
    </div>
  </div>
</div>