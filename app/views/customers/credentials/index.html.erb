<div class="container mx-auto px-4 py-8 max-w-4xl">
  <h1 class="text-3xl font-bold mb-8">Security Keys</h1>

  <div class="card bg-base-100 shadow-xl mb-6">
    <div class="card-body">
      <h2 class="card-title">Your Security Keys</h2>
      <p class="text-base-content/70 mb-4">
        Manage your security keys for passwordless authentication.
      </p>

      <% if @credentials.any? %>
        <div class="overflow-x-auto">
          <table class="table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Added</th>
                <th>Last Used</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @credentials.each do |credential| %>
                <tr>
                  <td>
                    <div class="font-medium"><%= credential.nickname || "Security Key" %></div>
                    <% if credential.name.present? %>
                      <div class="text-sm text-base-content/70"><%= credential.name %></div>
                    <% end %>
                  </td>
                  <td><%= credential.created_at.strftime("%B %d, %Y") %></td>
                  <td>
                    <% if credential.last_used_at %>
                      <%= time_ago_in_words(credential.last_used_at) %> ago
                    <% else %>
                      Never
                    <% end %>
                  </td>
                  <td>
                    <% if current_customer.can_delete_credential?(credential) %>
                      <%= button_to "Remove", 
                          customers_credential_path(credential), 
                          method: :delete,
                          data: { confirm: "Are you sure you want to remove this security key?" },
                          class: "btn btn-error btn-sm" %>
                    <% else %>
                      <span class="text-sm text-base-content/50">Last key</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="alert alert-warning">
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <span>You don't have any security keys set up.</span>
        </div>
      <% end %>

      <div class="card-actions justify-end mt-6">
        <%= link_to "Add Security Key", 
            new_customers_credential_path, 
            class: "btn btn-primary",
            data: { turbo_frame: "_top" } %>
      </div>
    </div>
  </div>

  <div class="text-center">
    <%= link_to "Back to Dashboard", root_path, class: "btn btn-ghost" %>
  </div>
</div>