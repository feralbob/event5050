<div class="min-h-screen flex items-center justify-center bg-base-200">
  <div class="card w-full max-w-md bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title text-2xl font-bold text-center mb-6">Set Up Security Key</h2>
      
      <div id="setup-form" data-controller="webauthn-registration">
        <p class="text-base-content/70 mb-6">
          To secure your account, you'll need to set up a security key. 
          This can be a physical security key, your device's fingerprint reader, or Face ID.
        </p>

        <div class="form-control mb-6">
          <label class="label">
            <span class="label-text">Give your security key a nickname (optional)</span>
          </label>
          <input type="text" 
                 placeholder="e.g., MacBook Touch ID, YubiKey"
                 class="input input-bordered w-full"
                 data-webauthn-registration-target="nickname">
        </div>

        <button class="btn btn-primary w-full" 
                data-action="click->webauthn-registration#register"
                data-webauthn-registration-target="button">
          Set Up Security Key
        </button>

        <div id="setup-prompt" class="hidden mt-6" data-webauthn-registration-target="prompt">
          <div class="text-center">
            <div class="loading loading-spinner loading-lg text-primary mb-4"></div>
            <p class="text-lg font-semibold mb-2">Setting up...</p>
            <p class="text-base-content/70">Please follow your browser's prompts to register your security key.</p>
          </div>
        </div>

        <div id="error-message" class="hidden alert alert-error mt-4" data-webauthn-registration-target="error">
          <span data-webauthn-registration-target="errorText"></span>
        </div>
      </div>

      <% if session[:pending_credential_setup].nil? %>
        <div class="divider"></div>
        <div class="text-center">
          <%= link_to "Cancel", customers_credentials_path, class: "btn btn-ghost btn-sm" %>
        </div>
      <% end %>
    </div>
  </div>
</div>