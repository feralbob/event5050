<div class="min-h-screen flex items-center justify-center bg-base-200">
  <div class="card w-full max-w-md bg-base-100 shadow-xl">
    <div class="card-body text-center">
      <div class="flex justify-center mb-4">
        <svg class="w-16 h-16 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
      </div>
      
      <h2 class="card-title text-2xl font-bold justify-center mb-4">Check Your Email</h2>
      
      <p class="text-base-content/70 mb-6">
        We've sent a confirmation link to your email address. 
        Please check your inbox and click the link to confirm your account.
      </p>
      
      <div class="alert alert-info">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span class="text-sm">Didn't receive the email? Check your spam folder.</span>
      </div>
      
      <div class="divider">OR</div>
      
      <div class="space-y-2">
        <%= link_to "Resend confirmation email", new_customers_confirmation_path, 
            class: "btn btn-outline btn-sm w-full" %>
        <%= link_to "Back to sign in", new_customers_session_path, 
            class: "btn btn-ghost btn-sm w-full" %>
      </div>
    </div>
  </div>
</div>