<div class="min-h-screen flex items-center justify-center bg-base-200">
  <div class="card w-full max-w-md bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title text-2xl font-bold text-center mb-6">Verify Your Identity</h2>
      
      <div data-controller="webauthn-reauthentication">
        <div id="reauthentication-form">
          <p class="text-base-content/70 mb-6">
            For your security, please verify your identity to continue managing your security keys.
          </p>

          <button type="button" 
                  class="btn btn-primary w-full btn-lg"
                  data-action="click->webauthn-reauthentication#authenticate"
                  data-webauthn-reauthentication-target="button">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0119.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 004.5 10.5a7.464 7.464 0 01-1.15 3.993m1.989 3.559A11.209 11.209 0 008.25 10.5a3.75 3.75 0 117.5 0c0 .527-.021 1.049-.064 1.565M12 10.5a14.94 14.94 0 01-3.6 9.75m6.633-4.596a18.666 18.666 0 01-2.485 5.33" />
            </svg>
            Verify with passkey
          </button>
        </div>

        <div id="webauthn-prompt" class="hidden" data-webauthn-reauthentication-target="prompt">
          <div class="text-center">
            <div class="loading loading-spinner loading-lg text-primary mb-4"></div>
            <p class="text-lg font-semibold mb-2">Verifying...</p>
            <p class="text-base-content/70">Please use your security key or biometric authentication.</p>
          </div>
        </div>

        <div id="error-message" class="hidden alert alert-error mt-4" data-webauthn-reauthentication-target="error">
          <span data-webauthn-reauthentication-target="errorText"></span>
        </div>
      </div>

      <div class="divider mt-8"></div>

      <div class="text-center">
        <%= link_to "Cancel", customers_credentials_path, class: "btn btn-ghost" %>
      </div>
    </div>
  </div>
</div>