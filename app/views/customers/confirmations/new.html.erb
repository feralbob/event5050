<div class="min-h-screen flex items-center justify-center bg-base-200">
  <div class="card w-full max-w-md bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title text-2xl font-bold text-center mb-6">Resend Confirmation</h2>
      
      <%= form_with(model: @customer, url: customers_confirmations_path, local: true) do |form| %>
        <% if @customer.errors.any? %>
          <div class="alert alert-error mb-4">
            <ul class="list-disc list-inside">
              <% @customer.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="form-control mb-6">
          <%= form.label :email, class: "label" %>
          <%= form.email_field :email, 
              class: "input input-bordered w-full", 
              placeholder: "john@example.com",
              required: true %>
          <label class="label">
            <span class="label-text-alt">Enter the email address you used to register</span>
          </label>
        </div>

        <div class="form-control">
          <%= form.submit "Resend Instructions", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <div class="divider"></div>

      <div class="text-center">
        <%= link_to "Back to sign in", new_customers_session_path, 
            class: "btn btn-ghost btn-sm" %>
      </div>
    </div>
  </div>
</div>