<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-8">Available Draws</h1>
  
  <% if @draws.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @draws.each do |draw| %>
        <div class="card bg-base-100 shadow-xl">
          <div class="card-body">
            <h2 class="card-title"><%= draw.raffle.name %></h2>
            <p class="text-sm text-gray-600"><%= draw.raffle.description %></p>
            
            <div class="mt-4">
              <p class="text-sm">Draw Date: <%= draw.draw_date.strftime("%B %d, %Y") %></p>
              <p class="text-sm">Sales End: <%= draw.ticket_sales_end_at.strftime("%B %d at %I:%M %p") %></p>
            </div>
            
            <div class="mt-4">
              <p class="text-lg font-semibold">Current Prize Pool</p>
              <p class="text-2xl font-bold text-primary">
                <%= format_money(draw.total_revenue) %>
              </p>
            </div>
            
            <div class="card-actions justify-end mt-4">
              <%= link_to "Buy Tickets", ticket_purchase_path(draw), 
                  class: "btn btn-primary" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      <span>No draws are currently available for ticket purchase.</span>
    </div>
  <% end %>
</div>